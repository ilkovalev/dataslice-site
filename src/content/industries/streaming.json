{
  "id": "streaming",
  "archetype": {
    "ru": "Подписки",
    "en": "Subscriptions"
  },
  "industry": {
    "ru": "Стриминг и подписки",
    "en": "Streaming & subscriptions"
  },
  "northStar": {
    "ru": "Retained Paying Subscribers (удерживаемые платящие)",
    "en": "Retained paying subscribers"
  },
  "root": {
    "id": "subs",
    "level": 0,
    "title": "Retained Paying Subscribers",
    "formula": {
      "ru": "Привлечение − Отток",
      "en": "Acquisition − Churn"
    },
    "note": {
      "ru": "Бизнес подписки живёт удержанием платящих: важнее не привлечь, а не потерять. База = приток − отток, и на зрелом рынке отток решает всё.",
      "en": "A subscription business lives on retaining payers: keeping matters more than acquiring. Base = inflow − churn, and in a mature market churn decides everything."
    },
    "children": [
      {
        "id": "acq",
        "level": 1,
        "title": {
          "ru": "Привлечение",
          "en": "Acquisition"
        },
        "formula": {
          "ru": "трафик × CR в подписку",
          "en": "traffic × subscribe CR"
        },
        "note": {
          "ru": "Приток новых платящих.",
          "en": "The inflow of new payers."
        },
        "children": [
          {
            "id": "trial",
            "level": 2,
            "metricId": "conversion-rate",
            "title": "Trial → Paid",
            "note": {
              "ru": "Доходят ли с пробного периода до первой оплаты.",
              "en": "Do trials reach the first payment."
            },
            "children": [
              {
                "id": "onb",
                "level": 3,
                "metricId": "activation-rate",
                "title": {
                  "ru": "Активация в онбординге",
                  "en": "Onboarding activation"
                },
                "note": {
                  "ru": "Дошёл ли новичок до первой ценности за пробный период.",
                  "en": "Did the newcomer reach first value within the trial."
                },
                "children": [
                  {
                    "id": "ttfv",
                    "level": 4,
                    "title": "Time to First Value",
                    "note": {
                      "ru": "Как быстро получил пользу: первый удачный фильм/плейлист.",
                      "en": "How fast value arrived: the first good movie/playlist."
                    },
                    "children": [
                      {
                        "id": "taste-onb",
                        "level": 5,
                        "kind": "lever",
                        "title": {
                          "ru": "Настройка вкуса на старте",
                          "en": "Taste setup at start"
                        },
                        "note": {
                          "ru": "Рычаг: выбор жанров/артистов в онбординге ускоряет первое попадание рекомендаций.",
                          "en": "Lever: picking genres/artists during onboarding speeds up the first recommendation hit."
                        }
                      }
                    ],
                    "metricId": "ttv"
                  }
                ]
              }
            ]
          },
          {
            "id": "cac",
            "level": 2,
            "metricId": "cac",
            "title": {
              "ru": "CAC канала",
              "en": "Channel CAC"
            },
            "note": {
              "ru": "Стоимость привлечения платящего по каналам.",
              "en": "Payer acquisition cost by channel."
            }
          }
        ],
        "kind": "group"
      },
      {
        "id": "ret",
        "level": 1,
        "metricId": "retention-n-day",
        "title": {
          "ru": "Удержание",
          "en": "Retention"
        },
        "formula": "1 − Churn",
        "note": {
          "ru": "Главный рычаг подписки: продление держится на использовании.",
          "en": "The subscription's main lever: renewal rests on usage."
        },
        "children": [
          {
            "id": "engage",
            "level": 2,
            "title": {
              "ru": "Вовлечённость",
              "en": "Engagement"
            },
            "note": {
              "ru": "Пользуются → продлевают; неиспользуемая подписка живёт до ревизии трат.",
              "en": "Use leads to renewal; an unused subscription lives until the next spending review."
            },
            "children": [
              {
                "id": "active-days",
                "level": 3,
                "metricId": "stickiness",
                "title": {
                  "ru": "Активные дни в месяц",
                  "en": "Active days per month"
                },
                "note": {
                  "ru": "Регулярность потребления — предиктор продления.",
                  "en": "Consumption regularity — the renewal predictor."
                },
                "children": [
                  {
                    "id": "content-fit",
                    "level": 4,
                    "title": {
                      "ru": "Нашёл, что смотреть/слушать",
                      "en": "Found something to watch/listen"
                    },
                    "note": {
                      "ru": "Совпал ли каталог с вкусом: сессии, закончившиеся потреблением.",
                      "en": "Did the catalog match the taste: sessions that end in consumption."
                    },
                    "children": [
                      {
                        "id": "reco-quality",
                        "level": 5,
                        "kind": "lever",
                        "title": {
                          "ru": "Качество рекомендаций",
                          "en": "Recommendation quality"
                        },
                        "note": {
                          "ru": "Рычаг: доля запусков из рекомендаций и «пустых» сессий без просмотра.",
                          "en": "Lever: share of plays from recommendations and \"empty\" sessions with no playback."
                        }
                      }
                    ],
                    "metricId": "search-success"
                  }
                ]
              }
            ],
            "kind": "group"
          },
          {
            "id": "involuntary",
            "level": 2,
            "title": {
              "ru": "Вынужденный отток",
              "en": "Involuntary churn"
            },
            "note": {
              "ru": "Слетел платёж: карта истекла, лимит, банк отклонил.",
              "en": "A failed payment: expired card, limit, bank decline."
            },
            "children": [
              {
                "id": "dunning",
                "level": 3,
                "kind": "lever",
                "title": {
                  "ru": "Recovery платежей",
                  "en": "Payment recovery"
                },
                "note": {
                  "ru": "Рычаг: ретраи, обновление карты, grace-период возвращают часть слетевших.",
                  "en": "Lever: retries, card updates and grace periods recover part of the failed."
                }
              }
            ],
            "metricId": "churn-rate"
          }
        ]
      },
      {
        "id": "arpu",
        "level": 1,
        "metricId": "arpu",
        "title": "ARPU",
        "formula": {
          "ru": "выручка / подписчики",
          "en": "revenue / subscribers"
        },
        "note": {
          "ru": "Доход с подписчика: второй множитель выручки после размера базы.",
          "en": "Revenue per subscriber: the second revenue factor after base size."
        },
        "children": [
          {
            "id": "tier",
            "level": 2,
            "kind": "lever",
            "title": {
              "ru": "Микс тарифов",
              "en": "Plan mix"
            },
            "note": {
              "ru": "Рычаг: доля дорогих планов и лестница «дешёвый с рекламой → премиум».",
              "en": "Lever: the share of premium plans and the \"cheap ad tier → premium\" ladder."
            },
            "children": [
              {
                "id": "tier-migration",
                "level": 3,
                "title": {
                  "ru": "Миграции между планами",
                  "en": "Plan migrations"
                },
                "note": {
                  "ru": "Апгрейды минус даунгрейды — денежное выражение микса.",
                  "en": "Upgrades minus downgrades — the mix in money terms."
                },
                "metricId": "mrr"
              }
            ]
          },
          {
            "id": "addon",
            "level": 2,
            "title": {
              "ru": "Доп-продукты",
              "en": "Add-ons"
            },
            "note": {
              "ru": "Апсейлы поверх подписки.",
              "en": "Upsells on top of the subscription."
            },
            "metricId": "mrr"
          }
        ]
      }
    ],
    "metricId": "retained-subscribers"
