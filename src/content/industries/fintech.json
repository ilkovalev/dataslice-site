                        "metricId": "activation-rate"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "active",
            "level": 2,
            "title": {
              "ru": "Доля активных (primary bank)",
              "en": "Primary-bank share"
