    "ru": "Сети физических точек",
    "en": "Physical location chains"
  },
  "industry": {
    "ru": "Ресторанные сети",
    "en": "Restaurant chains"
  },
  "northStar": {
    "ru": "Total Sales (или Number of Orders)",
    "en": "Total sales (or number of orders)"
  },
  "root": {
    "id": "sales",
    "level": 0,
    "title": "Total Sales",
    "formula": {
      "ru": "Точки × Выручка с точки",
      "en": "Locations × Sales per location"
    },
    "note": {
      "ru": "Сеть растёт двумя путями: открывать новые точки и поднимать выручку каждой (same-store). Смешивать эти два роста в одну цифру — классическая ошибка чтения отчётности сетей.",
      "en": "A chain grows two ways: opening new locations and raising each location's sales (same-store). Blending the two into one number is the classic mistake in reading chain reports."
    },
    "children": [
      {
        "id": "expansion",
        "level": 1,
        "title": {
          "ru": "Экспансия (число точек)",
          "en": "Expansion (location count)"
        },
        "formula": {
          "ru": "открытия − закрытия",
          "en": "openings − closures"
        },
        "note": {
          "ru": "Рост сети вширь: каждая точка — отдельная инвестиция со своей окупаемостью.",
          "en": "Growing wide: every location is a separate investment with its own payback."
        },
        "children": [
          {
            "id": "new-units",
            "level": 2,
            "title": {
              "ru": "Открытия",
              "en": "Openings"
            },
            "note": {
              "ru": "Темп новых точек и качество их запуска.",
              "en": "The pace of new locations and launch quality."
            },
            "children": [
              {
                "id": "payback",
                "level": 3,
                "metricId": "payback-period",
                "title": {
                  "ru": "Окупаемость точки",
                  "en": "Location payback"
                },
                "note": {
                  "ru": "Когда точка возвращает вложенное и выходит в плюс.",
                  "en": "When a location returns the investment and turns profitable."
                },
                "children": [
                  {
                    "id": "location",
                    "level": 4,
                    "kind": "lever",
                    "title": {
                      "ru": "Качество локации (трафик)",
                      "en": "Site quality (footfall)"
                    },
                    "note": {
                      "ru": "Рычаг: поток людей рядом с точкой — решение принимается до открытия.",
                      "en": "Lever: footfall near the site — decided before opening."
                    },
                    "children": [
                      {
                        "id": "site-model",
                        "level": 5,
                        "kind": "lever",
                        "title": {
                          "ru": "Модель выбора локаций",
                          "en": "Site-selection model"
                        },
                        "note": {
                          "ru": "Рычаг: прогноз выручки точки по гео-данным до подписания аренды.",
                          "en": "Lever: forecasting a site's sales from geo data before signing the lease."
                        }
                      }
                    ]
                  }
                ]
              }
            ],
            "metricId": "unit-payback"
          },
          {
            "id": "cannib",
            "level": 2,
            "title": {
              "ru": "Каннибализация",
              "en": "Cannibalization"
            },
            "note": {
              "ru": "Новая точка отъедает выручку у соседней: рост сети без роста продаж.",
              "en": "A new location eats a neighbor's sales: chain growth without sales growth."
