  "root": {
    "id": "orders",
    "level": 0,
    "metricId": "completed-orders",
    "title": "Completed Orders",
    "formula": {
      "ru": "Едоки × Частота × Fulfilment",
      "en": "Eaters × Frequency × Fulfilment"
    },
    "note": {
      "ru": "Трёхсторонняя платформа: едоки, рестораны, курьеры. Ценность — заказ, доставленный вовремя и горячим; на нём же держится юнит-экономика.",
      "en": "A three-sided platform: eaters, restaurants, couriers. The value is an order delivered on time and hot; unit economics rests on the same thing."
    },
    "children": [
      {
        "id": "eaters",
        "level": 1,
        "title": {
          "ru": "Едоки (спрос)",
          "en": "Eaters (demand)"
        },
        "formula": {
          "ru": "пользователи × частота",
          "en": "users × frequency"
        },
        "note": {
          "ru": "Сторона спроса: сколько людей заказывает и как часто.",
          "en": "The demand side: how many people order and how often."
        },
        "children": [
          {
            "id": "active-eaters",
            "level": 2,
            "metricId": "dau-mau",
            "title": {
              "ru": "Активные едоки",
              "en": "Active eaters"
            },
            "note": {
              "ru": "Кто реально заказывает за месяц.",
              "en": "Who actually orders in a month."
            },
            "children": [
              {
                "id": "eater-acq",
                "level": 3,
                "metricId": "cac",
                "title": {
                  "ru": "Привлечение едоков",
                  "en": "Eater acquisition"
                },
                "note": {
                  "ru": "CAC и промо первого заказа: скидка — это часть стоимости привлечения.",
                  "en": "CAC and first-order promos: the discount is part of acquisition cost."
                },
                "children": [
                  {
                    "id": "second-order",
                    "level": 4,
                    "metricId": "repeat-rate",
                    "title": {
                      "ru": "Конверсия во 2-й заказ",
                      "en": "Second-order conversion"
