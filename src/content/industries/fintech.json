  },
  "industry": {
    "ru": "Банкинг и финтех",
    "en": "Banking & fintech"
  },
  "northStar": {
    "ru": "TPV / активные платящие клиенты",
    "en": "TPV / active paying customers"
  },
  "root": {
    "id": "tpv",
    "level": 0,
    "metricId": "tpv",
    "title": {
      "ru": "TPV (оборот) / активные клиенты",
      "en": "TPV / active customers"
    },
    "formula": {
      "ru": "Клиенты × Активность × Чек операции",
      "en": "Customers × Activity × Transaction size"
    },
    "note": {
      "ru": "Финтех зарабатывает на потоке денег: проценты, комиссии, interchange. Чем больше оборот активных клиентов — тем больше доход, но каждый рубль оборота должен быть честным и рисково-взвешенным.",
      "en": "Fintech earns on money flow: interest, fees, interchange. The bigger the active customers' volume, the bigger the income — but every unit of flow must be honest and risk-weighted."
    },
    "children": [
      {
        "id": "base",
        "level": 1,
        "title": {
          "ru": "База клиентов",
          "en": "Customer base"
        },
        "formula": {
          "ru": "привлечение − отток",
          "en": "acquisition − churn"
        },
        "note": {
          "ru": "Сколько активных пользователей и становится ли банк основным.",
          "en": "How many active users there are and whether the bank becomes primary."
        },
        "children": [
          {
            "id": "acq",
            "level": 2,
            "metricId": "cac",
            "title": {
              "ru": "Привлечение",
              "en": "Acquisition"
            },
            "note": {
              "ru": "Каналы, реферралы и стоимость клиента.",
              "en": "Channels, referrals and customer cost."
            },
            "children": [
              {
                "id": "onb",
                "level": 3,
                "kind": "lever",
                "title": {
                  "ru": "Онбординг / KYC",
                  "en": "Onboarding / KYC"
                },
                "note": {
                  "ru": "Рычаг: доходят ли заявки до открытого счёта; каждый лишний шаг проверки — потери.",
                  "en": "Lever: do applications reach an open account; every extra verification step leaks users."
                },
                "children": [
                  {
                    "id": "first-tx",
                    "level": 4,
                    "metricId": "activation-rate",
                    "title": {
                      "ru": "Первая операция",
                      "en": "First transaction"
                    },
                    "note": {
                      "ru": "Активация: деньги пошли — счёт живой.",
                      "en": "Activation: money moved — the account is alive."
                    },
                    "children": [
                      {
                        "id": "funded-accounts",
                        "level": 5,
                        "title": {
                          "ru": "Доля пополненных счетов",
                          "en": "Funded-account share"
                        },
                        "note": {
                          "ru": "Счёт с деньгами против пустой регистрации — реальная база бизнеса.",
