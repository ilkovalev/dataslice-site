      "name": {
        "ru": "Яндекс Go",
        "en": "Yandex Go"
      },
      "northStar": {
        "ru": "Completed Rides (суперапп + экосистема)",
        "en": "Completed rides (super-app + ecosystem)"
      },
      "note": {
        "ru": "суперапп РФ: такси, доставка, самокаты в одном; ставка на экосистему Плюс и плотность городов.",
        "en": "a Russian super-app: rides, delivery, scooters in one; a bet on the Plus ecosystem and city density."
