{
  "id": "search",
  "archetype": {
    "ru": "Экономика внимания",
    "en": "Attention economy"
  },
  "industry": {
    "ru": "Поисковые сервисы",
    "en": "Search services"
  },
  "northStar": {
    "ru": "Successful Sessions (доля сессий с найденным ответом)",
    "en": "Successful sessions (share of sessions with an answer found)"
  },
  "root": {
    "id": "ss",
    "level": 0,
    "metricId": "search-success",
    "title": "Successful Sessions",
    "formula": {
      "ru": "Сессии × Success Rate",
      "en": "Sessions × Success rate"
    },
    "note": {
      "ru": "Парадокс поиска: ценность — в быстро закрытой потребности, а не во времени в продукте. Нашёл ответ → вернётся завтра → больше рекламных показов в выдаче.",
      "en": "The search paradox: value is a need closed fast, not time in product. Found the answer → comes back tomorrow → more ad impressions in results."
    },
    "children": [
      {
        "id": "demand",
        "level": 1,
        "title": {
          "ru": "Спрос (запросы)",
          "en": "Demand (queries)"
        },
        "formula": {
          "ru": "пользователи × запросы/пользователя",
          "en": "users × queries/user"
        },
        "note": {
          "ru": "Сколько вообще ищут: база пользователей × глубина привычки.",
          "en": "How much searching happens at all: user base × habit depth."
        },
        "children": [
          {
            "id": "users",
            "level": 2,
            "metricId": "dau-mau",
            "title": {
              "ru": "Активные пользователи",
              "en": "Active users"
            },
            "note": {
              "ru": "База ищущих.",
              "en": "The searching base."
            },
            "children": [
              {
                "id": "default",
                "level": 3,
                "title": {
                  "ru": "Доля «поиск по умолчанию»",
                  "en": "Default-search share"
                },
                "note": {
                  "ru": "Браузеры и устройства с этим поиском из коробки — главный канал дистрибуции.",
                  "en": "Browsers and devices shipping with this search — the main distribution channel."
                },
                "children": [
                  {
                    "id": "deals",
                    "level": 4,
                    "title": {
                      "ru": "Дистрибуционные сделки",
                      "en": "Distribution deals"
                    },
                    "note": {
                      "ru": "Договоры с вендорами устройств: покупка позиции по умолчанию.",
                      "en": "Deals with device vendors: buying the default slot."
                    },
                    "children": [
                      {
                        "id": "tac-cost",
                        "level": 5,
                        "title": {
                          "ru": "Стоимость дистрибуции",
                          "en": "Distribution cost"
                        },
                        "note": {
                          "ru": "Плата за трафик: дистрибуция — самая дорогая статья расходов поисковика.",
                          "en": "Traffic acquisition cost: distribution is a search engine's most expensive line."
                        },
                        "metricId": "cac"
                      }
                    ],
                    "metricId": "traffic"
                  }
                ],
                "metricId": "traffic"
              }
            ]
          },
          {
            "id": "qpu",
            "level": 2,
            "metricId": "sessions-per-user",
            "title": {
              "ru": "Запросов на пользователя",
              "en": "Queries per user"
            },
            "note": {
              "ru": "Глубина привычки искать именно здесь.",
              "en": "How deep the habit of searching here runs."
            }
          }
        ],
        "kind": "group"
      },
      {
        "id": "quality",
        "level": 1,
        "title": {
          "ru": "Качество выдачи",
          "en": "Result quality"
        },
        "formula": "Success Rate",
        "note": {
          "ru": "Решает, вернётся ли пользователь: поиск без качества теряет привычку за недели.",
          "en": "It decides whether the user returns: search without quality loses the habit in weeks."
        },
        "children": [
          {
            "id": "relevance",
            "level": 2,
            "kind": "lever",
            "title": {
              "ru": "Релевантность",
              "en": "Relevance"
            },
            "note": {
              "ru": "Рычаг: попал ли ранжировщик в намерение пользователя.",
              "en": "Lever: did ranking hit the user's intent."
            },
            "children": [
              {
                "id": "ctr-top",
                "level": 3,
                "metricId": "ctr",
                "title": {
                  "ru": "CTR верхних результатов",
                  "en": "Top-result CTR"
                },
                "note": {
                  "ru": "Кликают ли по первым ссылкам — первый признак попадания.",
                  "en": "Do people click the first links — the first sign of a hit."
                },
                "children": [
                  {
                    "id": "dwell",
                    "level": 4,
                    "title": "Dwell time",
                    "note": {
                      "ru": "Долго ли на странице: короткий клик и возврат = выдача обманула.",
                      "en": "How long they stay: a short click and a bounce back means the results lied."
                    },
                    "children": [
                      {
                        "id": "zero-click",
                        "level": 5,
                        "title": {
                          "ru": "Ответ без клика",
                          "en": "Zero-click answers"
                        },
                        "note": {
                          "ru": "Ответ прямо в выдаче: успех, который ломает все клик-метрики — считайте отдельно.",
                          "en": "The answer right on the page: a success that breaks every click metric — count it separately."
                        },
                        "metricId": "dwell-time"
                      }
                    ],
                    "metricId": "dwell-time"
                  }
                ]
              },
              {
                "id": "reformulate",
                "level": 3,
                "title": {
                  "ru": "Доля переформулировок",
                  "en": "Reformulation rate"
                },
                "note": {
                  "ru": "Пришлось переспрашивать — плохой сигнал: с первого раза не нашли.",
                  "en": "They had to ask again — a bad sign: the first try failed."
                },
                "metricId": "search-success"
              }
            ]
          },
          {
            "id": "speed",
            "level": 2,
            "metricId": "latency-p95",
            "title": {
              "ru": "Скорость выдачи",
              "en": "Result speed"
            },
            "note": {
              "ru": "Быстро ли пришёл ответ: в поиске задержка ощущается сильнее, чем где-либо.",
              "en": "How fast the answer came: in search, latency is felt more sharply than anywhere else."
            }
          }
        ],
        "kind": "group"
      },
      {
        "id": "monet",
        "level": 1,
        "title": {
          "ru": "Монетизация",
          "en": "Monetization"
        },
        "formula": {
          "ru": "запросы × Ad Coverage × CPC",
          "en": "queries × Ad coverage × CPC"
        },
        "note": {
          "ru": "Реклама в выдаче: платят за коммерческое намерение, а не за внимание.",
          "en": "Ads in results: advertisers pay for commercial intent, not attention."
        },
        "children": [
          {
            "id": "coverage",
            "level": 2,
            "kind": "lever",
            "title": "Ad Coverage",
            "note": {
              "ru": "Рычаг: доля запросов с рекламой; перебор выжигает доверие к выдаче.",
              "en": "Lever: the share of queries with ads; overdoing it burns trust in results."
            },
            "children": [
              {
                "id": "ad-ctr",
                "level": 3,
                "metricId": "ctr",
                "title": {
                  "ru": "CTR рекламы",
                  "en": "Ad CTR"
                },
                "note": {
                  "ru": "Кликают ли по объявлениям — релевантность работает и здесь.",
                  "en": "Do ads get clicked — relevance matters here too."
                },
                "children": [
                  {
                    "id": "ad-relevance",
                    "level": 4,
                    "title": {
                      "ru": "Релевантность объявлений",
                      "en": "Ad relevance"
                    },
                    "note": {
                      "ru": "Хорошая реклама на коммерческий запрос — тоже успех сессии, а не помеха.",
                      "en": "A good ad on a commercial query is a session success too, not an obstacle."
                    },
                    "metricId": "quality-score"
                  }
                ]
              }
            ]
          },
          {
            "id": "cpc",
            "level": 2,
            "title": {
              "ru": "CPC (цена клика)",
              "en": "CPC (cost per click)"
            },
            "note": {
              "ru": "Аукционная ставка: цену задаёт конкуренция рекламодателей за намерение.",
              "en": "The auction bid: price is set by advertisers competing for intent."
            },
            "metricId": "cpc"
          }
        ],
        "kind": "group"
      }
    ]
  },
