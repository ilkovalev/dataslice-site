{
  "id": "saas",
  "archetype": {
    "ru": "Подписки",
    "en": "Subscriptions"
  },
  "industry": "B2B SaaS",
  "northStar": "Net Revenue Retention (NRR)",
  "root": {
    "id": "nrr",
    "level": 0,
    "metricId": "nrr",
    "title": "Net Revenue Retention",
    "formula": {
      "ru": "(MRR + расширение − отток) / MRR",
      "en": "(MRR + expansion − churn) / MRR"
    },
    "note": {
      "ru": "Здоровье B2B SaaS: растёт ли выручка существующих клиентов сама. NRR > 100% — рост даже без новых продаж; раскладывается на новый MRR, расширение и отток.",
      "en": "B2B SaaS health: does existing-customer revenue grow by itself. NRR > 100% means growth even with zero new sales; decomposes into new MRR, expansion and churn."
    },
    "children": [
      {
        "id": "new",
        "level": 1,
        "metricId": "mrr",
        "title": {
          "ru": "Новый MRR",
          "en": "New MRR"
        },
        "formula": {
          "ru": "сделки × ACV",
          "en": "deals × ACV"
        },
        "note": {
          "ru": "Приток выручки от новых клиентов: продажи + self-serve.",
          "en": "Revenue inflow from new customers: sales plus self-serve."
        },
        "children": [
          {
            "id": "pipeline",
            "level": 2,
            "title": {
              "ru": "Воронка продаж",
              "en": "Sales pipeline"
            },
            "note": {
              "ru": "Лиды → квалификация → демо → сделка.",
              "en": "Leads → qualification → demo → deal."
            },
            "children": [
              {
                "id": "mql",
                "level": 3,
                "title": {
                  "ru": "Квалифицированные лиды (MQL)",
                  "en": "Qualified leads (MQL)"
                },
                "note": {
                  "ru": "Вход воронки: сколько лидов маркетинг передаёт продажам.",
                  "en": "The funnel's mouth: how many leads marketing hands to sales."
                },
                "children": [
                  {
                    "id": "winrate",
                    "level": 4,
                    "title": "Win Rate",
                    "formula": {
                      "ru": "выиграно / все сделки",
                      "en": "won / all deals"
                    },
                    "note": {
                      "ru": "Доля сделок, закрытых в оплату.",
                      "en": "Share of deals closed-won."
                    },
                    "children": [
                      {
                        "id": "salescycle",
                        "level": 5,
                        "title": {
                          "ru": "Длина цикла сделки",
                          "en": "Sales cycle length"
                        },
                        "note": {
                          "ru": "Дни от лида до оплаты; длинный цикл замораживает пайплайн и прогноз.",
                          "en": "Days from lead to payment; a long cycle freezes pipeline and forecast."
                        },
                        "metricId": "win-rate"
                      }
                    ],
                    "metricId": "win-rate"
                  }
                ],
                "metricId": "win-rate"
              }
            ],
            "kind": "group"
          },
          {
            "id": "plg",
            "level": 2,
            "title": {
              "ru": "Product-led рост",
              "en": "Product-led growth"
            },
            "note": {
              "ru": "Self-serve вход: продукт продаёт себя сам, продажи подключаются на расширении.",
              "en": "Self-serve entry: the product sells itself, sales joins at expansion."
            },
            "children": [
              {
                "id": "signup-active",
                "level": 3,
                "metricId": "activation-rate",
                "title": "Signup → Activated",
                "note": {
                  "ru": "Дошёл ли новый воркспейс до aha-момента.",
                  "en": "Did the new workspace reach the aha moment."
                },
                "children": [
                  {
                    "id": "onboarding",
                    "level": 4,
                    "kind": "lever",
                    "title": {
                      "ru": "Онбординг",
                      "en": "Onboarding"
                    },
                    "note": {
                      "ru": "Рычаг: шаблоны, чек-листы, пустые состояния — путь к первой ценности.",
                      "en": "Lever: templates, checklists, empty states — the path to first value."
                    },
                    "children": [
                      {
                        "id": "ttv",
                        "level": 5,
                        "title": {
                          "ru": "Time-to-Value",
                          "en": "Time to value"
                        },
                        "note": {
                          "ru": "Время от регистрации до первой пользы; каждый лишний день режет конверсию в платящих.",
                          "en": "Time from sign-up to first value; every extra day cuts paid conversion."
                        },
                        "metricId": "ttv"
                      }
                    ]
                  }
                ]
              }
            ],
            "kind": "group"
          }
        ]
      },
      {
        "id": "expansion",
        "level": 1,
        "title": {
          "ru": "Расширение (Expansion)",
          "en": "Expansion"
        },
        "formula": {
          "ru": "апсейл + места",
          "en": "upsell + seats"
        },
        "note": {
          "ru": "Главный драйвер NRR: существующие клиенты платят больше.",
          "en": "The main NRR driver: existing customers paying more."
        },
        "children": [
          {
            "id": "seats",
            "level": 2,
            "title": {
              "ru": "Рост числа мест",
              "en": "Seat growth"
            },
            "note": {
              "ru": "Команда клиента растёт внутри продукта.",
              "en": "The customer's team grows inside the product."
            },
            "children": [
              {
                "id": "adoption",
                "level": 3,
                "title": {
                  "ru": "Глубина внедрения",
                  "en": "Adoption depth"
                },
                "note": {
                  "ru": "Сколько фич и сценариев реально используют.",
                  "en": "How many features and workflows are actually used."
                },
                "children": [
                  {
                    "id": "dau-seat",
                    "level": 4,
                    "metricId": "dau-mau",
                    "title": {
                      "ru": "Активные на место",
                      "en": "Active per seat"
