{
  "id": "ondemand",
  "archetype": {
    "ru": "Транзакционные платформы",
    "en": "Transactional platforms"
  },
  "industry": {
    "ru": "Такси и доставка (on-demand)",
    "en": "Rides & delivery (on-demand)"
  },
  "northStar": {
    "ru": "Completed Rides / Orders (успешные поездки)",
    "en": "Completed rides / orders"
  },
  "root": {
    "id": "rides",
    "level": 0,
    "metricId": "completed-orders",
    "title": "Completed Rides",
    "formula": {
      "ru": "Запросы × Fulfilment Rate",
      "en": "Requests × fulfilment rate"
    },
    "note": {
      "ru": "Реальная ценность — состоявшаяся поездка: в ней сошлись спрос, предложение и матчинг. Платформа берёт комиссию с каждой.",
      "en": "The real value is a completed ride: demand, supply and matching met in it. The platform takes a commission on each."
    },
    "children": [
      {
        "id": "riders",
        "level": 1,
        "title": {
          "ru": "Спрос (пассажиры)",
          "en": "Demand (riders)"
        },
        "formula": {
          "ru": "пользователи × частота",
          "en": "users × frequency"
        },
        "note": {
          "ru": "Сторона спроса: сколько людей и как часто вызывают машину.",
          "en": "The demand side: how many people request rides and how often."
        },
        "children": [
          {
            "id": "active-riders",
            "level": 2,
            "metricId": "dau-mau",
            "title": {
              "ru": "Активные пассажиры",
              "en": "Active riders"
            },
            "note": {
              "ru": "Кто реально ездит за месяц, а не просто установил приложение.",
              "en": "Who actually rides in a month, not who merely installed the app."
            },
            "children": [
              {
                "id": "rider-acq",
                "level": 3,
                "metricId": "cac",
                "title": {
                  "ru": "Привлечение пассажиров",
                  "en": "Rider acquisition"
                },
                "note": {
                  "ru": "CAC пассажира и конверсия установки в первую поездку.",
                  "en": "Rider CAC and install-to-first-ride conversion."
                },
                "children": [
                  {
                    "id": "first-ride",
                    "level": 4,
                    "metricId": "activation-rate",
                    "title": {
                      "ru": "Установка → первая поездка",
                      "en": "Install → first ride"
                    },
                    "note": {
                      "ru": "Активация: первый успешный заказ в первые дни после установки.",
                      "en": "Activation: a first successful ride within days of install."
                    }
                  }
                ]
              },
              {
                "id": "freq",
                "level": 3,
                "metricId": "purchase-frequency",
                "title": {
                  "ru": "Поездок на пассажира",
                  "en": "Rides per rider"
                },
                "note": {
                  "ru": "Частота использования — главный рычаг зрелого рынка.",
                  "en": "Usage frequency — the main lever in a mature market."
                },
                "children": [
                  {
                    "id": "habit",
                    "level": 4,
                    "title": {
                      "ru": "Доля «привычных» сценариев",
                      "en": "Habitual use cases"
                    },
                    "note": {
                      "ru": "Дом—работа, аэропорт, вечер пятницы: сценарии, где вызов машины стал привычкой.",
                      "en": "Home–work, airport, Friday night: scenarios where hailing a ride became a habit."
                    },
                    "children": [
                      {
                        "id": "retention-riders",
                        "level": 5,
                        "metricId": "retention-n-day",
                        "title": {
                          "ru": "Retention пассажиров",
                          "en": "Rider retention"
                        },
                        "note": {
                          "ru": "Возвращаемость когорт: привычка видна в кривой удержания, вышедшей на плато.",
                          "en": "Cohort returns: habit shows as a retention curve flattening into a plateau."
                        }
                      }
                    ],
                    "metricId": "retention-n-day"
                  }
                ]
              }
            ]
          }
        ],
        "kind": "group"
      },
      {
        "id": "drivers",
        "level": 1,
        "title": {
          "ru": "Предложение (водители)",
          "en": "Supply (drivers)"
        },
        "formula": {
          "ru": "водители × часы онлайн",
          "en": "drivers × online hours"
        },
        "note": {
          "ru": "Мощность платформы измеряется не числом аккаунтов, а человеко-часами на линии.",
          "en": "Platform capacity is measured in online person-hours, not account counts."
        },
        "children": [
          {
            "id": "active-drivers",
            "level": 2,
            "title": {
              "ru": "Активные водители",
              "en": "Active drivers"
            },
            "note": {
              "ru": "Доступная мощность: часы онлайн в нужных районах в нужное время.",
              "en": "Available capacity: online hours in the right areas at the right time."
            },
            "children": [
              {
                "id": "driver-acq",
                "level": 3,
                "title": {
                  "ru": "Привлечение и онбординг",
                  "en": "Driver acquisition & onboarding"
                },
                "note": {
                  "ru": "Время от заявки до первой смены: документы, проверки, обучение.",
                  "en": "Time from application to first shift: documents, checks, training."
                },
                "kind": "group"
              },
              {
                "id": "utilization",
                "level": 3,
                "title": {
                  "ru": "Утилизация водителя",
                  "en": "Driver utilization"
                },
                "formula": {
                  "ru": "время в заказе / время онлайн",
                  "en": "on-trip time / online time"
                },
                "note": {
                  "ru": "Доля времени на линии, проведённая с пассажиром, — эффективность и заработок.",
                  "en": "Share of online time spent with a rider — efficiency and earnings."
                },
                "children": [
                  {
                    "id": "earnings",
                    "level": 4,
                    "title": {
                      "ru": "Заработок в час",
                      "en": "Hourly earnings"
                    },
                    "note": {
                      "ru": "Главное, что удерживает водителя на вашей платформе, а не у конкурента.",
                      "en": "The main thing keeping a driver on your platform instead of a competitor's."
                    },
                    "children": [
                      {
                        "id": "driver-churn",
                        "level": 5,
                        "metricId": "churn-rate",
                        "title": {
                          "ru": "Отток водителей",
                          "en": "Driver churn"
                        },
                        "note": {
                          "ru": "Уход исполнителей схлопывает предложение — и ликвидность за ним.",
                          "en": "Provider churn collapses supply — and liquidity with it."
                        }
                      }
                    ],
                    "metricId": "hourly-earnings"
                  }
                ],
                "metricId": "utilization"
              }
            ],
            "metricId": "provider-availability"
          }
        ],
        "kind": "group"
      },
      {
        "id": "match",
        "level": 1,
        "metricId": "liquidity",
        "title": {
          "ru": "Ликвидность / матчинг",
          "en": "Liquidity / matching"
        },
        "formula": "Fulfilment Rate",
        "note": {
          "ru": "Связывает стороны вовремя: доля запросов, закончившихся поездкой.",
          "en": "Connects the sides on time: the share of requests ending in a ride."
        },
        "children": [
          {
            "id": "eta",
            "level": 2,
            "metricId": "time-to-match",
            "title": {
              "ru": "Время подачи (ETA)",
              "en": "Pickup time (ETA)"
            },
            "note": {
              "ru": "Сколько ждать машину; медиана и p90 по районам и часам.",
              "en": "How long the car takes; median and p90 by area and hour."
            },
            "children": [
              {
                "id": "density",
                "level": 3,
                "title": {
                  "ru": "Плотность водителей",
                  "en": "Driver density"
                },
                "note": {
                  "ru": "Водителей на район: плотность делает подачу короткой, а поездку дешёвой.",
                  "en": "Drivers per area: density makes pickups short and rides cheap."
                },
                "children": [
                  {
                    "id": "cancel",
                    "level": 4,
                    "metricId": "cancellation-rate",
                    "title": {
                      "ru": "Доля отмен",
                      "en": "Cancellation rate"
                    },
                    "note": {
                      "ru": "Не дождался, нет машин, водитель отменил — разбирается по инициатору.",
                      "en": "Gave up waiting, no cars, driver cancelled — broken down by initiator."
                    },
                    "children": [
                      {
                        "id": "cancel-reasons",
                        "level": 5,
                        "title": {
                          "ru": "Отмены по причинам",
                          "en": "Cancellations by reason"
                        },
                        "note": {
                          "ru": "Долгий ETA, цена, ошибка адреса: каждую причину чинит своя команда.",
                          "en": "Long ETA, price, wrong address: each cause is fixed by a different team."
                        },
                        "metricId": "cancellation-rate"
                      }
                    ]
                  }
                ],
                "metricId": "driver-density"
              }
            ]
          },
          {
            "id": "surge",
            "level": 2,
            "kind": "lever",
            "title": {
              "ru": "Динамическое ценообразование",
              "en": "Dynamic pricing"
            },
            "note": {
              "ru": "Рычаг: сурж балансирует спрос и предложение в пике — и злит пассажиров при перегибе.",
              "en": "Lever: surge balances demand and supply at peak — and angers riders when overdone."
            },
            "children": [
              {
                "id": "surge-share",
                "level": 3,
                "title": {
                  "ru": "Доля поездок с суржем",
                  "en": "Surged ride share"
                },
                "note": {
                  "ru": "Постоянный сурж — сигнал хронической нехватки предложения, а не «удачной» монетизации.",
                  "en": "Constant surge signals a chronic supply shortage, not \"successful\" monetization."
                },
                "metricId": "surge-share"
              }
            ]
          }
        ]
      }
    ]
